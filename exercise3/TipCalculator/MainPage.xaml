<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TipCalculator"
             x:Class="TipCalculator.MainPage">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto, Auto, Auto"
          ColumnDefinitions="*, *"
          Padding="40">

        <Label Text="Note / facture" VerticalOptions="Center" Grid.Row="0" Grid.Column="0" />
        <Entry x:Name="billInput" Placeholder="Entre le total (ex: 50)" Keyboard="Numeric" Grid.Row="0" Grid.Column="1" />

        <Label Text="Pourboire estimé" Grid.Row="1" Grid.Column="0" />
        <Label x:Name="tipOutput" Text="0.00" Grid.Row="1" Grid.Column="1" />

        <Label Text="Total (avec pourboire)" Grid.Row="2" Grid.Column="0" />
        <Label x:Name="totalOutput" Text="0.00" Grid.Row="2" Grid.Column="1" />

        <Label Text="Pourcentage de pourboire"
               VerticalOptions="End"
               HorizontalOptions="Start"
               Grid.Row="3"
               Grid.Column="0" />
        <Label x:Name="tipPercent"
               Text="15%"
               VerticalOptions="End"
               HorizontalOptions="End"
               Grid.Row="3"
               Grid.Column="1" />
        <Slider x:Name="tipPercentSlider" Minimum="0" Maximum="100" Value="15" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" />

        <Button Text="Rapide 15%" Clicked="OnNormalTip" Margin="5" Grid.Row="5" Grid.Column="0" />
        <Button Text="Rapide 20%" Clicked="OnGenerousTip" Margin="5" Grid.Row="5" Grid.Column="1" />

        <Button x:Name="roundDown" Text="Arrondir (bas)" Margin="5" Grid.Row="6" Grid.Column="0" />
        <Button x:Name="roundUp"   Text="Arrondir (haut)" Margin="5" Grid.Row="6" Grid.Column="1" />

    </Grid>

</ContentPage>
