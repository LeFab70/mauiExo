<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TipCalculator"
             x:Class="TipCalculator.MainPage">

    <VerticalStackLayout>

        <Label Text="Note / facture" />
        <Entry x:Name="billInput" Placeholder="Entre le total (ex: 50)" Keyboard="Numeric" />

        <Label Text="Pourboire estimé" />
        <Label x:Name="tipOutput" Text="0.00" />

        <Label Text="Total (avec pourboire)" />
        <Label x:Name="totalOutput" Text="0.00" />

        <Label Text="Pourcentage de pourboire" />
        <Label x:Name="tipPercent" Text="15%" />
        <Slider x:Name="tipPercentSlider" Minimum="0" Maximum="100" Value="15" />

        <Button Text="Rapide 15%" Clicked="OnNormalTip" />
        <Button Text="Rapide 20%" Clicked="OnGenerousTip" />

        <Button x:Name="roundDown" Text="Arrondir (bas)" />
        <Button x:Name="roundUp"   Text="Arrondir (haut)" />

    </VerticalStackLayout>

</ContentPage>
