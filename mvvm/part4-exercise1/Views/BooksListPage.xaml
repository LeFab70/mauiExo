<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BookCatalog.ViewModels"
             xmlns:local="clr-namespace:BookCatalog"
             x:Class="BookCatalog.Views.BooksListPage"
             x:DataType="vm:BookListViewModel"
             Title="Livres - Fabrice"
             BindingContext="{x:Static local:App.MainViewModel}">
    <ListView ItemsSource="{Binding Books}" Margin="10" ItemTapped="ListView_ItemTapped">
        <ListView.ItemTemplate>
            <DataTemplate>
                <TextCell Text="{Binding Title}" x:DataType="vm:BookViewModel">
                    <TextCell.ContextActions>
                        <MenuItem Text="Supprimer" IsDestructive="True" Clicked="MenuItem_Clicked" />
                    </TextCell.ContextActions>
                </TextCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentPage>