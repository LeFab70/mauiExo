<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TipCalculator"
             x:Class="TipCalculator.MainPage">

    <VerticalStackLayout>

        <Label Text="Montant de l’addition" />
        <Entry x:Name="billInput" Placeholder="Saisis un montant (ex: 24,90)" Keyboard="Numeric" />

        <Label Text="Pourboire" />
        <Label x:Name="tipOutput" Text="0.00" />

        <Label Text="Total à payer" />
        <Label x:Name="totalOutput" Text="0.00" />

        <Label Text="Taux de pourboire" />
        <Label x:Name="tipPercent" Text="15%" />
        <Slider x:Name="tipPercentSlider" Minimum="0" Maximum="100" Value="15" />

        <Button Text="Standard (15%)" Clicked="OnNormalTip" />
        <Button Text="Généreux (20%)" Clicked="OnGenerousTip" />

        <Button x:Name="roundDown" Text="Arrondir en dessous" />
        <Button x:Name="roundUp"   Text="Arrondir au dessus" />

    </VerticalStackLayout>

</ContentPage>
